---
import { Icon } from 'astro-icon/components';
import { getMessages } from "../constants/messages";

const pathname = Astro.url.pathname;
interface Props {
  lang?: 'ja' | 'en';
  alternateUrl?: string;
}

const { lang, alternateUrl } = Astro.props as Props;
const currentLang = lang || (pathname.startsWith('/ja/') ? 'ja' : 'en');

const getAlternateUrl = (targetLang: 'ja' | 'en') => {
  if (alternateUrl) {
    const alternateLang = currentLang === 'ja' ? 'en' : 'ja';
    if (targetLang === alternateLang) {
      return alternateUrl;
    }
    return pathname;
  }
  // デフォルトの動作：単純にパスの言語部分を置き換え
  const pathWithoutLang = pathname.replace(/^\/(ja|en)(?=\/|$)/, '') || '/';
  return `/${targetLang}${pathWithoutLang}`;
};

const msg = getMessages(currentLang);

---

<header class="site-header">
  <div class="site-header-inner">
    <a class="site-title" href={`/${currentLang}/models`}>MENTAL MODEL ATLAS</a>
    <div class="header-right">
    <form action={`/${currentLang}/models`} method="get" class="header-search-form">
      <div class="header-search-wrapper">
        <Icon name="lucide:search" size={16} class="search-icon" />
        <input 
          type="text" 
          name="q"
          class="header-search" 
          placeholder={msg.searchPlaceholder}
          aria-label="Search mental models"
        />
      </div>
    </form>
      <nav class="header-nav">
        <a href={`/${currentLang}/models`}>Models</a>
        <a href={`/${currentLang}/about`}>About</a>
      </nav>
      <span class="header-divider"></span>
      <div class="language-switcher">
        <a href={getAlternateUrl('ja')} class={currentLang === 'ja' ? 'active' : ''}>
          JA
        </a>
        <span class="separator">/</span>
        <a href={getAlternateUrl('en')} class={currentLang === 'en' ? 'active' : ''}>
          EN
        </a>
      </div>
      <span class="header-divider"></span>
      <a class="social-link" href="https://github.com/rikuya-osawa/mental-model-atlas" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <Icon name="simple-icons:github" size={20}/>
      </a>
    </div>
  </div>
</header>

<script type="module" define:vars={{ currentLang }}>
  // --- スクロール動作 ---
  (() => {
    const header = document.querySelector('.site-header');
    if (!header) return;

    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 50;

    function onScroll() {
      const y = window.scrollY;
      if (y <= 0) {
        header.classList.remove('site-header--hidden');
        lastY = y;
        return;
      }
      if (y > lastY && y > THRESHOLD) {
        header.classList.add('site-header--hidden');
      } else if (y < lastY) {
        header.classList.remove('site-header--hidden');
      }
      lastY = y;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();

  // --- 検索ロジック ---
  function initSearch() {
    const searchForm = document.querySelector('.header-search-form');
    const searchInput = document.querySelector('.header-search');
    const searchIcon = document.querySelector('.search-icon');

    if (!searchForm || !searchInput) return;

    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const query = searchInput.value.trim();
      
      const url = new URL(window.location.origin + `/${currentLang}/models`);
      if (query) {
        url.searchParams.set('q', query);
      }

      if (window.location.pathname !== `/${currentLang}/models`) {
        window.location.href = url.toString();
      } else {
        window.history.pushState({}, '', url);
        
        if (typeof window.updateAllFilters === 'function') {
          window.updateAllFilters();
        }
        
        searchInput.value = '';
        searchInput.blur();
      }
    });

    // 検索アイコンクリック時にフォーム送信
    if (searchIcon) {
      searchIcon.addEventListener('click', (e) => {
        e.preventDefault();
        searchForm.requestSubmit();
      });
    }

    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q && window.location.pathname === `/${currentLang}/models`) {
      searchInput.value = q;
      if (typeof window.updateAllFilters === 'function') {
        window.updateAllFilters();
      }
    }
  }

  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>