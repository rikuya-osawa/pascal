---
import { Icon } from 'astro-icon/components';
import { getCollection } from "astro:content";
import ModelCard from "../model-card.astro";
import { NATURES, APPLICATION, getLabel, type Language } from "../../constants/filters";
import { UI_ICONS } from '../../constants/model-icons';
import { getMessages } from "../../constants/messages";
import { GITHUB_URL } from "../../constants/site-config";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const collectionName = `${lang}/models` as const;
const allModels = await getCollection(collectionName);

const natureList = Object.entries(NATURES);
const viewList = Object.entries(APPLICATION);

const msg = getMessages(lang);
const modelRequestUrl = `${GITHUB_URL}/issues/new/choose`;

// モデルの統計情報
const totalCount = allModels.length;
const natureCounts = {
  FRAMEWORK: allModels.filter(m => m.data.nature === 'FRAMEWORK').length,
  COGNITION: allModels.filter(m => m.data.nature === 'COGNITION').length,
  PRINCIPLE: allModels.filter(m => m.data.nature === 'PRINCIPLE').length,
};
---

<!-- Page Hero Section -->
<section class="models-hero">
  <div class="models-hero-content">
    <h1 class="models-hero-title">{msg.modelsPageTitle}</h1>
    <p class="models-hero-desc">{msg.modelsPageDesc}</p>
    
    <div class="models-stats">
      <div class="stat-item stat-total">
        <span class="stat-number">{totalCount}</span>
        <span class="stat-label">{msg.modelsTotalCount}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item stat-nature" data-nature="FRAMEWORK">
        <span class="stat-number">{natureCounts.FRAMEWORK}</span>
        <span class="stat-label">{getLabel(NATURES.FRAMEWORK, lang)}</span>
      </div>
      <div class="stat-item stat-nature" data-nature="COGNITION">
        <span class="stat-number">{natureCounts.COGNITION}</span>
        <span class="stat-label">{getLabel(NATURES.COGNITION, lang)}</span>
      </div>
      <div class="stat-item stat-nature" data-nature="PRINCIPLE">
        <span class="stat-number">{natureCounts.PRINCIPLE}</span>
        <span class="stat-label">{getLabel(NATURES.PRINCIPLE, lang)}</span>
      </div>
    </div>
  </div>
</section>

<!-- Filter Section -->
<section class="filter-section">
  <button
    class="filter-toggle"
    id="open-filter-panel"
    type="button"
    aria-controls="filter-panel"
    aria-expanded="false"
  >
    <Icon name={UI_ICONS.filter} class="filter-icon filter-icon-open" />
    <Icon name={UI_ICONS.filterClose} class="filter-icon filter-icon-close" />
    <span>{msg.modelsFilterTitle}</span>
  </button>
</section>

<aside id="filter-panel" class="filter-panel is-open" aria-hidden="false" aria-label={msg.modelsFilterTitle}>
  <div class="filter-panel-header">
    <h2 class="filter-section-title">{msg.modelsFilterTitle}</h2>
    <div class="filter-panel-actions">
      <button class="filter-reset" id="reset-filter-panel" type="button" aria-label={msg.modelsResetFiltersAriaLabel}>
        <Icon name={UI_ICONS.filterReset} class="filter-reset-icon" />
        <span>{msg.modelsResetFilters}</span>
      </button>
      <button
        class="filter-close"
        id="close-filter-panel"
        type="button"
        aria-label={`Close ${msg.modelsFilterTitle} panel`}
      >
        <Icon name={UI_ICONS.filterClose} class="filter-close-icon" />
      </button>
    </div>
  </div>

  <div class="filter-container">
    <div class="filter-group">
      <span class="filter-label">
        <svg class="filter-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="3 3 21 3 21 9 12 18 3 9 3 3"></polygon>
        </svg>
        {msg.natureLabel}
      </span>
      <div class="filter-options">
        <button class="filter-link" data-type="nature" data-value="">{msg.allLabel}</button>
        {natureList.map(([id, labels]) => (
          <button
            class="filter-link"
            data-type="nature"
            data-value={id}
          >
            {getLabel(labels, lang)}
          </button>
        ))}
      </div>
    </div>

    <div class="filter-group">
      <span class="filter-label">
        <svg class="filter-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
        </svg>
        {msg.applicationLabel}
      </span>
      <div class="filter-options">
        <button class="filter-link" data-type="view" data-value="">{msg.allLabel}</button>
        {viewList.map(([id, labels]) => (
          <button
            class="filter-link"
            data-type="view"
            data-value={id}
          >
            {getLabel(labels, lang)}
          </button>
        ))}
      </div>
    </div>
  </div>
</aside>

<!-- Models Grid -->
<div class="model-grid">
  {allModels.filter(Boolean).map((model) => (
      <ModelCard model={model} lang={lang} />
  ))}
</div>
<div id="search-fallback" class="hidden">
  <p class="search-fallback-message">{msg.searchFallback}</p>
  <p class="search-fallback-help">{msg.modelsRequestDescription}</p>
  <a
    class="search-fallback-button"
    href={modelRequestUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    {msg.modelsRequestCta}
  </a>
  <a>{msg.modelsRequestDescription}</a>
</div>

<script define:vars={{ searchPlaceholder: msg.searchPlaceholder }}>
  const links = document.querySelectorAll('.filter-link');
  const items = document.querySelectorAll('.model-item');
  const openFilterPanelButton = document.getElementById('open-filter-panel');
  const closeFilterPanelButton = document.getElementById('close-filter-panel');
  const resetFilterPanelButton = document.getElementById('reset-filter-panel');
  const filterPanel = document.getElementById('filter-panel');

  function openFilterPanel() {
    filterPanel?.classList.add('is-open');
    filterPanel?.setAttribute('aria-hidden', 'false');
    openFilterPanelButton?.setAttribute('aria-expanded', 'true');
  }

  function closeFilterPanel() {
    filterPanel?.classList.remove('is-open');
    filterPanel?.setAttribute('aria-hidden', 'true');
    openFilterPanelButton?.setAttribute('aria-expanded', 'false');
  }

  function toggleFilterPanel() {
    if (filterPanel?.classList.contains('is-open')) {
      closeFilterPanel();
      return;
    }
    openFilterPanel();
  }

  function updateAllFilters() {
    const url = new URL(window.location.href);
    const activeNature = url.searchParams.get('nature');
    const activeView = url.searchParams.get('view');
    const activeQuery = url.searchParams.get('q')?.toLowerCase() || "";

    // 1. リンク（ボタン）の見た目更新
    links.forEach(link => {
      const type = link.getAttribute('data-type');
      const value = link.getAttribute('data-value');
      if (!type) return;

      const currentParam = url.searchParams.get(type);
      if ((!currentParam && !value) || (currentParam === value)) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    // 2. カードの表示・非表示判定
    items.forEach(item => {
      const itemNature = item.getAttribute('data-nature');
      const itemViews = item.getAttribute('data-views')?.split(',') || [];
      const itemTitle = item.querySelector('.card-title')?.textContent.toLowerCase() || "";

      // 排他的ロジック：各パラメータが存在する場合のみチェック
      const natureMatch = !activeNature || itemNature === activeNature;
      const viewMatch = !activeView || itemViews.includes(activeView);
      const queryMatch = !activeQuery || itemTitle.includes(activeQuery);

      if (natureMatch && viewMatch && queryMatch) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
      }
    });

    // 3. フォールバックの制御
    const fallback = document.getElementById('search-fallback');
    if (fallback) {
      const anyVisible = Array.from(items).some(item => !item.classList.contains('hidden'));
      fallback.classList.toggle('hidden', anyVisible);
    }

    // 検索クエリがあり、結果が1件のみなら詳細ページへ遷移
    if (activeQuery) {
      const visibleItems = Array.from(items).filter(item => !item.classList.contains('hidden'));
      if (visibleItems.length === 1) {
        const onlyLink = visibleItems[0].querySelector('.card-link');
        if (onlyLink instanceof HTMLAnchorElement) {
          window.location.href = onlyLink.href;
          return;
        }
      }
    }
  }

  // グローバルに公開（Header から呼び出す）
  window.updateAllFilters = updateAllFilters;

  openFilterPanelButton?.addEventListener('click', toggleFilterPanel);
  closeFilterPanelButton?.addEventListener('click', closeFilterPanel);

  resetFilterPanelButton?.addEventListener('click', () => {
    const url = new URL(window.location.href);
    url.searchParams.delete('nature');
    url.searchParams.delete('view');
    url.searchParams.delete('q');
    window.history.pushState({}, '', url);
    updateAllFilters();

    const searchInput = document.querySelector('.header-search');
    if (searchInput instanceof HTMLInputElement) {
      searchInput.value = '';
      searchInput.placeholder = searchPlaceholder;
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && filterPanel?.classList.contains('is-open')) {
      closeFilterPanel();
    }
  });

  links.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const type = link.getAttribute('data-type');
      const value = link.getAttribute('data-value');
      if (!type) return;

      const url = new URL(window.location.href);

      url.searchParams.delete('q');

      if (value) {
        url.searchParams.set(type, value);
      } else {
        url.searchParams.delete(type);
      }

      window.history.pushState({}, '', url);
      updateAllFilters();

      const searchInput = document.querySelector('.header-search');
      if (searchInput) {
        searchInput.placeholder = searchPlaceholder;
      }
    });
  });

  window.addEventListener('popstate', updateAllFilters);
  document.addEventListener('astro:page-load', () => {
    openFilterPanel();
    updateAllFilters();
  });
  openFilterPanel();
  updateAllFilters();
</script>
