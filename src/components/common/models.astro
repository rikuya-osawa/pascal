---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import ModelCard from "../model-card.astro";
import { NATURES, getLabel, type Language } from "../../constants/filters";
import { UI_ICONS } from "../../constants/model-icons";
import { getMessages } from "../../constants/messages";
import { GITHUB_URL } from "../../constants/site-config";
import { STORAGE_KEYS } from "../../constants/storage-keys";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const collectionName = `${lang}/models` as const;
const allModels = await getCollection(collectionName);

const msg = getMessages(lang);
const modelRequestUrl = `${GITHUB_URL}/issues/new/choose`;

// モデルの統計情報
const totalCount = allModels.length;
const natureCounts = allModels.reduce(
  (counts, model) => {
    const nature = model.data.nature;
    if (nature in counts) {
      counts[nature as keyof typeof counts] += 1;
    }
    return counts;
  },
  {
    FRAMEWORK: 0,
    COGNITION: 0,
    PRINCIPLE: 0,
  },
);
---

<!-- Page Hero Section -->
<section class="models-hero">
  <div class="models-hero-content">
    <h1 class="models-hero-title">{msg.modelsPageTitle}</h1>
    <p class="models-hero-desc">{msg.modelsPageDesc}</p>

    <div class="models-stats">
      <div class="stat-item stat-total">
        <span class="stat-number">{totalCount}</span>
        <span class="stat-label">{msg.modelsTotalCount}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item stat-nature" data-nature="FRAMEWORK">
        <span class="stat-number">{natureCounts.FRAMEWORK}</span>
        <span class="stat-label">{getLabel(NATURES.FRAMEWORK, lang)}</span>
      </div>
      <div class="stat-item stat-nature" data-nature="COGNITION">
        <span class="stat-number">{natureCounts.COGNITION}</span>
        <span class="stat-label">{getLabel(NATURES.COGNITION, lang)}</span>
      </div>
      <div class="stat-item stat-nature" data-nature="PRINCIPLE">
        <span class="stat-number">{natureCounts.PRINCIPLE}</span>
        <span class="stat-label">{getLabel(NATURES.PRINCIPLE, lang)}</span>
      </div>
    </div>
  </div>
</section>

<!-- Filter Section -->
<section class="filter-section">
  <button
    class="filter-toggle"
    id="open-filter-panel"
    type="button"
    aria-controls="filter-panel"
    aria-expanded="false"
  >
    <Icon name={UI_ICONS.filter} class="filter-icon filter-icon-open" />
    <Icon name={UI_ICONS.filterClose} class="filter-icon filter-icon-close" />
    <span>{msg.modelsFilterTitle}</span>
  </button>
</section>

<!-- Models Grid -->
<div class="model-grid">
  {
    allModels
      .filter(Boolean)
      .map((model) => <ModelCard model={model} lang={lang} />)
  }
</div>
<div id="search-fallback" class="hidden">
  <p class="search-fallback-message">{msg.searchFallback}</p>
  <p class="search-fallback-help">{msg.modelsRequestDescription}</p>
  <a
    class="search-fallback-button"
    href={modelRequestUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    {msg.modelsRequestCta}
  </a>
</div>

<script
  define:vars={{
    searchPlaceholder: msg.searchPlaceholder,
    filterPanelStorageKey: STORAGE_KEYS.filterPanelOpen,
    modelFiltersStorageKey: STORAGE_KEYS.modelFilters,
  }}
>
  const filterLinks = Array.from(document.querySelectorAll(".filter-link"));
  const modelItems = Array.from(document.querySelectorAll(".model-item"));
  const openFilterPanelButton = document.getElementById("open-filter-panel");
  const closeFilterPanelButton = document.getElementById("close-filter-panel");
  const resetFilterPanelButton = document.getElementById("reset-filter-panel");
  const filterPanel = document.getElementById("filter-panel");
  const searchFallback = document.getElementById("search-fallback");

  function getSearchInput() {
    const input = document.querySelector(".header-search");
    return input instanceof HTMLInputElement ? input : null;
  }

  function getFilterStateFromUrl() {
    const url = new URL(window.location.href);
    return {
      url,
      activeNature: url.searchParams.get("nature") || "",
      activeMethodology: url.searchParams.get("methodology") || "",
      activeTag: url.searchParams.get("tag") || "",
      activeQuery: (url.searchParams.get("q") || "").toLowerCase(),
    };
  }

  function persistFilterPanelState(isOpen) {
    try {
      window.localStorage.setItem(filterPanelStorageKey, String(isOpen));
    } catch {
      // Ignore storage failures and keep runtime behavior intact.
    }
  }

  function getPersistedFilterPanelState() {
    try {
      return window.localStorage.getItem(filterPanelStorageKey) === "true";
    } catch {
      return false;
    }
  }

  function persistModelFilters(nature, methodology, tag) {
    try {
      if (!nature && !methodology && !tag) {
        window.localStorage.removeItem(modelFiltersStorageKey);
        return;
      }

      window.localStorage.setItem(
        modelFiltersStorageKey,
        JSON.stringify({ nature, methodology, tag }),
      );
    } catch {
      // Ignore storage failures and keep runtime behavior intact.
    }
  }

  function getPersistedModelFilters() {
    try {
      const raw = window.localStorage.getItem(modelFiltersStorageKey);
      if (!raw) return null;

      const parsed = JSON.parse(raw);
      const nature = typeof parsed?.nature === "string" ? parsed.nature : "";
      const methodology =
        typeof parsed?.methodology === "string" ? parsed.methodology : "";
      const tag = typeof parsed?.tag === "string" ? parsed.tag : "";

      if (!nature && !methodology && !tag) return null;
      return { nature, methodology, tag };
    } catch {
      return null;
    }
  }

  function restoreModelFiltersIntoUrl() {
    const url = new URL(window.location.href);
    if (
      url.searchParams.has("nature") ||
      url.searchParams.has("methodology") ||
      url.searchParams.has("tag")
    )
      return;

    const persisted = getPersistedModelFilters();
    if (!persisted) return;

    if (persisted.nature) {
      url.searchParams.set("nature", persisted.nature);
    }

    if (persisted.methodology) {
      url.searchParams.set("methodology", persisted.methodology);
    }

    if (persisted.tag) {
      url.searchParams.set("tag", persisted.tag);
    }

    window.history.replaceState({}, "", url);
  }

  function setFilterPanelOpenState(isOpen) {
    filterPanel?.classList.toggle("is-open", isOpen);
    filterPanel?.setAttribute("aria-hidden", String(!isOpen));
    document.body.classList.toggle("filter-panel-open", isOpen);
    openFilterPanelButton?.setAttribute("aria-expanded", String(isOpen));
    persistFilterPanelState(isOpen);
  }

  function openFilterPanel() {
    setFilterPanelOpenState(true);
  }

  function closeFilterPanel() {
    setFilterPanelOpenState(false);
  }

  function restoreFilterPanelState() {
    if (getPersistedFilterPanelState()) {
      openFilterPanel();
      return;
    }

    closeFilterPanel();
  }

  function toggleFilterPanel() {
    if (filterPanel?.classList.contains("is-open")) {
      closeFilterPanel();
      return;
    }
    openFilterPanel();
  }

  function updateActiveFilterLinkStates(url) {
    filterLinks.forEach((link) => {
      const type = link.getAttribute("data-type");
      const value = link.getAttribute("data-value") || "";
      if (!type) return;

      const currentParam = url.searchParams.get(type) || "";
      const isActive = (!currentParam && !value) || currentParam === value;
      link.classList.toggle("active", isActive);
    });
  }

  function applyItemVisibility(
    activeNature,
    activeMethodology,
    activeTag,
    activeQuery,
  ) {
    let visibleCount = 0;
    let onlyVisibleLink = null;

    modelItems.forEach((item) => {
      const itemNature = item.getAttribute("data-nature") || "";
      const itemMethodology = (item.getAttribute("data-methodology") || "")
        .split(",")
        .filter(Boolean);
      const itemTag = (item.getAttribute("data-tag") || "")
        .split(",")
        .filter(Boolean);
      const itemTitle =
        item.querySelector(".card-title")?.textContent.toLowerCase() || "";

      const natureMatch = !activeNature || itemNature === activeNature;
      const methodologyMatch =
        !activeMethodology || itemMethodology.includes(activeMethodology);
      const tagMatch = !activeTag || itemTag.includes(activeTag);
      const queryMatch = !activeQuery || itemTitle.includes(activeQuery);
      const isVisible =
        natureMatch && methodologyMatch && tagMatch && queryMatch;

      item.classList.toggle("hidden", !isVisible);

      if (isVisible) {
        visibleCount += 1;
        const link = item.querySelector(".card-link");
        if (visibleCount === 1 && link instanceof HTMLAnchorElement) {
          onlyVisibleLink = link;
        } else {
          onlyVisibleLink = null;
        }
      }
    });

    return { visibleCount, onlyVisibleLink };
  }

  function updateSearchFallbackVisibility(visibleCount) {
    searchFallback?.classList.toggle("hidden", visibleCount > 0);
  }

  function updateAllFilters() {
    const { url, activeNature, activeMethodology, activeTag, activeQuery } =
      getFilterStateFromUrl();

    persistModelFilters(activeNature, activeMethodology, activeTag);

    updateActiveFilterLinkStates(url);

    const { visibleCount, onlyVisibleLink } = applyItemVisibility(
      activeNature,
      activeMethodology,
      activeTag,
      activeQuery,
    );

    updateSearchFallbackVisibility(visibleCount);

    // 検索クエリがあり、結果が1件のみなら詳細ページへ遷移
    if (
      activeQuery &&
      visibleCount === 1 &&
      onlyVisibleLink instanceof HTMLAnchorElement
    ) {
      window.location.href = onlyVisibleLink.href;
    }
  }

  // グローバルに公開（Header から呼び出す）
  window.updateAllFilters = updateAllFilters;

  openFilterPanelButton?.addEventListener("click", toggleFilterPanel);
  closeFilterPanelButton?.addEventListener("click", closeFilterPanel);

  resetFilterPanelButton?.addEventListener("click", () => {
    const url = new URL(window.location.href);
    url.searchParams.delete("nature");
    url.searchParams.delete("methodology");
    url.searchParams.delete("tag");
    url.searchParams.delete("q");
    window.history.pushState({}, "", url);
    persistModelFilters("", "", "");
    updateAllFilters();

    const searchInput = getSearchInput();
    if (searchInput) {
      searchInput.value = "";
      searchInput.placeholder = searchPlaceholder;
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && filterPanel?.classList.contains("is-open")) {
      closeFilterPanel();
    }
  });

  filterLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const type = link.getAttribute("data-type");
      const value = link.getAttribute("data-value") || "";
      if (!type) return;

      const url = new URL(window.location.href);

      url.searchParams.delete("q");

      if (value) {
        url.searchParams.set(type, value);
      } else {
        url.searchParams.delete(type);
      }

      window.history.pushState({}, "", url);
      updateAllFilters();

      const searchInput = getSearchInput();
      if (searchInput) {
        searchInput.placeholder = searchPlaceholder;
      }
    });
  });

  function initializeModelsPage() {
    restoreModelFiltersIntoUrl();
    restoreFilterPanelState();
    updateAllFilters();
  }

  window.addEventListener("popstate", updateAllFilters);
  document.addEventListener("astro:before-swap", () => {
    document.body.classList.remove("filter-panel-open");
  });
  document.addEventListener("astro:page-load", initializeModelsPage);
  initializeModelsPage();
</script>
