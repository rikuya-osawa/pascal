---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { MODEL_ICONS } from "../constants/model-icons";
import {
  NATURES,
  METHODOLOGY,
  TAGS,
  getLabel,
  getMethodologyLabel,
  type Language,
} from "../constants/filters";

type ModelEntry = CollectionEntry<"ja/models"> | CollectionEntry<"en/models">;

interface Props {
  model: ModelEntry | null | undefined;
  lang: Language;
}

const { model, lang } = Astro.props as Props;
if (!model) {
  return null;
}

const modelSlug = model.slug.includes("/")
  ? model.slug.split("/").pop() || model.slug
  : model.slug;
const iconName = MODEL_ICONS[modelSlug] || MODEL_ICONS.default;

const natureKey = model.data.nature as keyof typeof NATURES;
const natureLabel = NATURES[natureKey]
  ? getLabel(NATURES[natureKey], lang)
  : model.data.nature;

const methodologyCodes = Array.isArray(model.data.methodology)
  ? model.data.methodology
  : [];
const methodologyLabels = methodologyCodes.map((methodology) => {
  const methodologyKey = methodology.toUpperCase() as keyof typeof METHODOLOGY;
  return METHODOLOGY[methodologyKey]
    ? getMethodologyLabel(METHODOLOGY[methodologyKey], lang)
    : methodology;
});

const tagCodes = Array.isArray(model.data.tags) ? model.data.tags : [];
---

<div
  class="card model-item"
  data-nature={model.data.nature}
  data-methodology={methodologyCodes.join(",")}
  data-tag={tagCodes.join(",")}
>
  <a href={`/${lang}/models/${modelSlug}`} class="card-link">
    <div class="card-nature-top">
      <span class={`badge nature badge--${model.data.nature.toLowerCase()}`}>
        {natureLabel}
      </span>
    </div>

    <div class="card-header card-header-vertical">
      <Icon name={iconName} class="card-icon" />
      <h2 class="card-title">
        {model.data.name}
      </h2>
    </div>

    {
      model.data.description && (
        <p class="card-description">{model.data.description}</p>
      )
    }

    <div class="card-meta">
      {
        methodologyLabels.map((methodologyLabel) => (
          <span class="badge methodology">{methodologyLabel}</span>
        ))
      }
    </div>
  </a>
</div>
