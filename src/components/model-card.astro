---
import { Icon } from 'astro-icon/components';
import { MODEL_ICONS } from '../constants/model-icons';
import { APPLICATION, NATURES, getLabel, type Language } from '../constants/filters';

interface Props {
  model: any;
  lang: Language;
}

const { model, lang } = Astro.props;
if (!model) {
  console.warn("ModelCard: model is undefined");
  return null;
}

const iconName = MODEL_ICONS[model.slug] || MODEL_ICONS["default"];

const natureKey = model.data.nature as keyof typeof NATURES;
const natureLabel = NATURES[natureKey] ? getLabel(NATURES[natureKey], lang) : model.data.nature;
const applicationLabels: string[] = (model.data.application || []).map((application: keyof typeof APPLICATION) => {
  return APPLICATION[application] ? getLabel(APPLICATION[application], lang) : application;
});
---

<div
  class="card model-item"
  data-nature={model?.data?.nature}
  data-views={model?.data?.application?.join(',')}
>
  <a href={`/${lang}/models/${model.slug.split('/').pop()}`} class="card-link">
    <div class="card-nature-top">
      <span class={`badge nature badge--${model.data.nature.toLowerCase()}`}>
        {natureLabel}
      </span>
    </div>

    <div class="card-header card-header-vertical">
      <Icon name={iconName} class="card-icon" />
      <h2 class="card-title">
        {lang === 'ja' ? model.data.name : model.data.name}
      </h2>
    </div>

    {model.data.description && (
      <p class="card-description">
        {model.data.description}
      </p>
    )}

    <div class="card-meta">
      {applicationLabels.map((applicationLabel) => (
        <span class="badge application">
          {applicationLabel}
        </span>
      ))}
    </div>
  </a>
</div>