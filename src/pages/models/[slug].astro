---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allModels = await getCollection('ja/models');
  
  return allModels.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. getStaticPaths から渡された props を受け取る
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{entry.data.official_name}</title>
  </head>
  <body>
    <a href="/models">← 一覧に戻る</a>
    <article>
      <Content />
    </article>
    <a href="/models">← 一覧に戻る</a>
  </body>
</html>