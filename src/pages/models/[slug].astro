---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/markdown.css";

export async function getStaticPaths() {
  const allModels = await getCollection("ja/models");

  return allModels.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. getStaticPaths から渡された props を受け取る
const { entry } = Astro.props;
const { Content } = await entry.render();

// Schema.org 用データを組み立てる
const site = Astro.site || 'https://mental-model-atlas.pages.dev';
// Astro.url はページの絶対パス部分のみなので、base を付与
const pageUrl = new URL(Astro.url, site).toString();
const schemaData = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entry.data.official_name,
  description: entry.data.description,
  image: ["https://mental-model-atlas.pages.dev/default-og.png"],
  datePublished: "2026-02-25T00:00:00+09:00",
  dateModified: new Date().toISOString(),
  author: {
    "@type": "Organization",
    name: "Mental Model Atlas",
  },
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "ホーム",
      item: site + "/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "モデル一覧",
      item: site + "/models",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.official_name,
      item: pageUrl,
    },
  ],
};
---

<BaseLayout>
  <!-- structured data for search engines -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />

  <a href="/models">← 一覧に戻る</a>
  <article class="markdown-content">
    <h1>{entry.data.official_name}</h1>
    <div class="meta">
      <span class="badge">{entry.data.layer}</span>
      {entry.data.viewpoints.map((v) => <span class="badge">{v}</span>)}
    </div>
    <Content content={entry.body} />
  </article>
  <a href="/models">← 一覧に戻る</a>
</BaseLayout>
