---
import "../styles/global.css";
import "../styles/components.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const { title, description } = Astro.props;
const siteName = "Mental Model Atlas";
const fullTitle = title ? `${title} | ${siteName}` : siteName;
const defaultDesc = "日本語圏最大のメンタルモデル辞書。意思決定を支える「思考の地図」を提供します。";

const pathname = Astro.url.pathname;
const currentLang = pathname.startsWith('/ja/') ? 'ja' : 'en';
---

<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <title>{fullTitle}</title>
    <meta name="description" content={description || defaultDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={Astro.url} />
    {/*
      Named slot allows individual pages to inject extra <head> elements such as
      JSON-LD structured data (schema.org) or additional meta tags.
      Usage in a page:
        <script slot="head" type="application/ld+json" set:html={...} />
    */}
    <slot name="head" />
  </head>
  <body>
    <Header />
    <div class="container">
      <slot />
    </div>
    <Footer />
  </body>
</html>