---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base-layout.astro";
import "../../styles/markdown.css";
import "../../styles/components/model-detail.css";
import { LAYERS, APPLICATION, type Language } from "../../../constants/filters";
import { getMessages } from "../../../constants/messages";
import ModelCard from "../../../components/model-card.astro";
import { validateModelSync } from "../../../utils/validator";

export async function getStaticPaths() {
  const jaEntries = await getCollection("ja/models");
  const enEntries = await getCollection("en/models");

  validateModelSync(jaEntries, enEntries);

  return [
    ...jaEntries.map((entry) => ({
      params: {
        lang: "ja",
        slug: entry.slug.split("/").pop(),
      },
      props: { entry, lang: "ja" as const },
    })),
    ...enEntries.map((entry) => ({
      params: {
        lang: "en",
        slug: entry.slug.split("/").pop(),
      },
      props: { entry, lang: "en" as const },
    })),
  ];
}

const { entry, lang } = Astro.props;
const currentLang = lang as Language;
const msg = getMessages(currentLang);

const collectionName = `${currentLang}/models` as const;
const allModels = await getCollection(collectionName);
const modelBySlug = new Map(allModels.map((model) => [model.slug.split("/").pop(), model]));
const currentSlug = entry.slug.split("/").pop();
const relatedModels = (entry.data.related_models || [])
  .map((slug) => modelBySlug.get(slug))
  .filter((model): model is NonNullable<typeof model> => Boolean(model && model.slug.split("/").pop() !== currentSlug));

const { Content } = await entry.render();

// Schema.org 用データを組み立てる
const site = Astro.site || 'https://mental-model-atlas.pages.dev';
// Astro.url はページの絶対パス部分のみなので、base を付与
const pageUrl = new URL(Astro.url, site).toString();
const schemaData = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entry.data.name,
  description: entry.data.description,
  image: ["https://mental-model-atlas.pages.dev/default-og.png"],
  datePublished: "2026-02-25T00:00:00+09:00",
  dateModified: new Date().toISOString(),
  author: {
    "@type": "Organization",
    name: "Mental Model Atlas",
  },
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: msg.modelDetailHome,
      item: site + "/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: msg.modelDetailModels,
      item: site + `/${currentLang}/models`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.name,
      item: pageUrl,
    },
  ],
};

const layerInfo = LAYERS[entry.data.layer as keyof typeof LAYERS];
---

<BaseLayout lang={currentLang}>
  <a href={`/${currentLang}/models`}>{msg.goBackText}</a>
  
  <article class="markdown-content">
   
    <div class="meta">
      <span class={`badge badge--${entry.data.layer.toLowerCase()}`}>
        {layerInfo[currentLang]}
      </span>

      {entry.data.application.map((v) => {
        const viewInfo = APPLICATION[v as keyof typeof APPLICATION];
        return <span class="badge">{viewInfo[currentLang]}</span>;
      })}
    </div>

    <Content content={entry.body} />
  </article>

  {relatedModels.length > 0 && (
    <section class="related-models-section" aria-labelledby="related-models-title">
      <h2 id="related-models-title" class="related-models-title">{msg.modelDetailRelatedTitle}</h2>
      <div class="model-grid related-models-grid">
        {relatedModels.map((relatedModel) => (
          <ModelCard model={relatedModel} lang={currentLang} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
